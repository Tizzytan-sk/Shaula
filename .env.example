# Shaula Agent local environment example

# Web server port used by the packaged CLI.
PORT=30142

# Optional bind host. Leave empty for the default host behavior.
# HOSTNAME=127.0.0.1

# Shaula app-state root. Defaults to ~/.shaula.
# SHAULA_HOME=~/.shaula

# Optional default cwd and file-access sandbox root. When unset, the app starts
# in the user home directory but the file picker can browse any local drive.
# SHAULA_WEB_ROOT=/path/to/workspace/root

# Optional shell override for agent command execution. On Windows Shaula uses
# Git Bash when found, otherwise falls back to PowerShell automatically.
# SHAULA_SHELL_PATH=C:\Program Files\PowerShell\7\pwsh.exe

# Desktop update source.
SHAULA_UPDATE_OWNER=Tizzytan-sk
SHAULA_UPDATE_REPO=Shaula

# Disable browser auto-open when starting the CLI.
# BROWSER=none
