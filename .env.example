# Shaula Agent local environment example

# Web server port used by the packaged CLI.
PORT=30142

# Optional bind host. Leave empty for the default host behavior.
# HOSTNAME=127.0.0.1

# Shaula app-state root. Defaults to ~/.shaula.
# SHAULA_HOME=~/.shaula

# File picker and cwd sandbox root. Defaults to the user home directory.
# SHAULA_WEB_ROOT=/path/to/workspace/root

# Desktop update source.
SHAULA_UPDATE_OWNER=Tizzytan-sk
SHAULA_UPDATE_REPO=Shaula

# Disable browser auto-open when starting the CLI.
# BROWSER=none
